# Copy this file to .secrets and fill the values.
# This file is safe to commit; .secrets is gitignored.

# Bitwarden API key credentials.
BW_CLIENTID=""
BW_CLIENTSECRET=""

# Master password used to unlock Bitwarden CLI.
BW_PASSWORD=""

# Bitwarden item names used by scripts.
# NAS item should be a Login item with username/password.
BW_NAS_ITEM_NAME="NAS Credentials"
